NODE_ENV=development

API_PORT=9000

LOG_LEVEL=info
LOG_FILE_PATH=logs/app-{date}.log

PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=elysia_demo

JWT_SECRET=replace-me-with-strong-secret
JWT_EXPIRES_IN=1h
# JWT_EXPIRES_IN_SECONDS=3600
JWT_REFRESH_EXPIRES_IN_SECONDS=604800

REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379
# CORS_ALLOW_ORIGINS=https://admin.example.com,https://web.example.com

RATE_LIMIT_MAX=100
RATE_LIMIT_DURATION=60000
RATE_LIMIT_MAX_AUTH=20
RATE_LIMIT_MAX_WRITE=60
RATE_LIMIT_MAX_READ=180

STORAGE_TYPE=local
LOCAL_BASE_DIR=uploads
LOCAL_BASE_URL=http://localhost:9000/uploads

# OSS_REGION=oss-cn-hangzhou
# OSS_ACCESS_KEY_ID=your_access_key_id
# OSS_ACCESS_KEY_SECRET=your_access_key_secret
# OSS_BUCKET=your_bucket_name
# OSS_CDN_URL=https://your-cdn-url.com

# COS_SECRET_ID=your_secret_id
# COS_SECRET_KEY=your_secret_key
# COS_BUCKET=your_bucket_name
# COS_REGION=ap-guangzhou
# COS_CDN_URL=https://your-cdn-url.com

# Optional feature flags (default false)
# FEATURE_MONITOR_ENABLED=true
# FEATURE_IP_BLACKLIST_ENABLED=true
