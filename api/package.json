{
  "name": "harbor-api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/app/index.ts",
    "build": "bun build src/app/index.ts --target bun --outdir dist",
    "start": "bun dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test --preload ./tests/setup-env.ts",
    "test:unit": "bun test --preload ./tests/setup-env.ts tests/unit",
    "test:integration": "bun test --preload ./tests/setup-env.ts tests/integration",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun src/infra/db/client.ts seed",
    "db:check": "bun src/infra/db/client.ts check",
    "dev:check": "bun run db:check && bun run openapi:generate && bun run typecheck",
    "module:create": "bun scripts/create-module.ts",
    "openapi:generate": "bun scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.0",
    "@elysiajs/openapi": "^1.4.14",
    "ali-oss": "^6.23.0",
    "cos-js-sdk-v5": "^1.10.1",
    "croner": "^10.0.1",
    "drizzle-orm": "0.45.2",
    "elysia": "^1.4.10",
    "elysia-di": "^1.0.7",
    "elysia-rate-limit": "^4.5.1",
    "ioredis": "^5.8.1",
    "pino": "^9.9.4",
    "postgres": "^3.4.7",
    "proxy-agent": "^8.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.23.3",
    "@types/bun": "^1.3.0",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.9.3"
  }
}
