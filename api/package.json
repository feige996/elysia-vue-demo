{
    "name": "alova-elysia-demo-api",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "bun --watch src/app/index.ts",
        "build": "bun build src/app/index.ts --target bun --outdir dist",
        "start": "bun dist/index.js",
        "typecheck": "tsc --noEmit",
        "test": "bun test",
        "test:unit": "bun test tests/unit",
        "test:integration": "bun test tests/integration",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "db:seed": "bun src/infra/db/client.ts seed",
        "db:check": "bun src/infra/db/client.ts check",
        "module:create": "bun scripts/create-module.ts"
    },
    "dependencies": {
        "@elysiajs/cors": "^1.4.1",
        "@elysiajs/jwt": "^1.4.0",
        "drizzle-orm": "^0.44.6",
        "elysia": "^1.4.10",
        "elysia-di": "^1.0.7",
        "pino": "^9.9.4",
        "postgres": "^3.4.7",
        "zod": "^4.1.12"
    },
    "devDependencies": {
        "@types/bun": "^1.3.0",
        "drizzle-kit": "^0.31.4",
        "typescript": "^5.9.3"
    }
}
