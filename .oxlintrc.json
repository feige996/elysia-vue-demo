{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "bun.lock",
    "coverage/**"
  ],
  "plugins": ["eslint", "typescript", "unicorn", "oxc"],
  "rules": {
    "unicorn/no-useless-fallback-in-spread": "off",
    "no-unused-vars": "off"
  },
  "overrides": [
    {
      "files": ["admin/**/*.vue", "web/**/*.vue"],
      "plugins": ["eslint", "typescript", "unicorn", "oxc", "vue"]
    }
  ]
}
